# OpenFleet — Environment Variables
#
# Copy this file to .env and fill in your values.
# For local Docker Compose, the defaults here work as-is.
# For production, rotate all secrets before deploying.
#
# Usage with Docker Compose:
#   cp .env.example .env
#   docker compose up --build
#
# Usage with dotnet run (non-Docker):
#   Set these as environment variables or edit appsettings.Development.json

# ──────────────────────────────────────────────────
# ASP.NET Core
# ──────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ──────────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────────
POSTGRES_DB=openfleet
POSTGRES_USER=openfleet
POSTGRES_PASSWORD=openfleet_pass

# Connection string used by the API container
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=openfleet;Username=openfleet;Password=openfleet_pass

# ──────────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────────
# Must be at least 32 characters for HMAC-SHA256.
# Generate a strong secret before deploying to production:
#   openssl rand -base64 48
JwtSettings__SecretKey=super-secret-key-change-me-in-production-32chars
JwtSettings__Issuer=OpenFleet
JwtSettings__Audience=OpenFleetUsers
JwtSettings__ExpiryMinutes=60

# ──────────────────────────────────────────────────
# Logging (optional overrides)
# ──────────────────────────────────────────────────
# Serilog__MinimumLevel__Default=Information
# Serilog__MinimumLevel__Override__Microsoft.AspNetCore=Warning
