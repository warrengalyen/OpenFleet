# OpenFleet Web - Environment Variables
# Copy to .env.local for local development.
# All VITE_ prefixed vars are exposed to the browser bundle.

# Backend API origin (no trailing slash, no /api suffix).
# Leave unset for local dev so the client uses relative /api and Vite proxies it.
# Set for production builds (Render injects this via render.yaml).
# VITE_API_BASE_URL=https://openfleet-api.onrender.com
